PORT=5000
NODE_ENV="production"

# Локально — используются DB_* переменные ниже.
# На Railway добавь Postgres-плагин — он сам создаст переменную DATABASE_URL,
# и db.js подключится через неё (DB_* переменные при этом не нужны).
DATABASE_URL=
DB_NAME=notes
DB_USER=postgres
DB_PASSWORD="root"
DB_HOST=localhost
DB_PORT=5432

SESSION_SECRET=sadda

# На Railway — адрес твоего фронтенда на Vercel (например https://myapp.vercel.app)
CLIENT_URL=http://localhost:3000
